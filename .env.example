# ─── Required ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (provision via Replit DB or external provider)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session encryption secret — use a long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=your-super-secret-random-string-here

# ─── Optional: External API Keys ─────────────────────────────────────────────
# AISStream.io — live vessel positions (https://aisstream.io)
AIS_STREAM_API_KEY=

# Zyla Labs RapidAPI — vessel & port lookup (https://rapidapi.com/zyla-labs-zyla-labs-default/api/vessel-information-api)
VESSEL_API_KEY=

# Trading Economics — Baltic freight indices (https://tradingeconomics.com/api)
TRADING_ECONOMICS_API_KEY=

# Resend — transactional email (https://resend.com) — used when Replit connector is unavailable
RESEND_API_KEY=

# ─── Replit AI Integration (auto-injected in Replit environment) ──────────────
# These are set automatically by the Replit Anthropic integration — do not set manually
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=

# ─── Replit Connector Tokens (auto-injected in Replit environment) ────────────
# These are set automatically by Replit — do not set manually
# REPLIT_CONNECTORS_HOSTNAME=
# REPL_IDENTITY=
# WEB_REPL_RENEWAL=

# ─── Frontend (Vite — prefix with VITE_ to expose to browser) ────────────────
# Mapbox GL JS public token (https://mapbox.com)
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token-here

# ─── Server Settings ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
